{
  "name": "react-nerdery",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "RAVN Nerdery deliverables (weeks 1-3) with automated acceptance tests.",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:week1": "vitest run deliverables/week-1",
    "test:week2": "vitest run deliverables/week-2",
    "test:week3": "vitest run deliverables/week-3",
    "coverage": "vitest run --coverage",
    "grade:testing": "vitest run --coverage deliverables/week-2/testing",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "grade": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
